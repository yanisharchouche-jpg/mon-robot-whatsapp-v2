# ============================================================
# LIGHTFUNNEL → WHATSAPP NOTIFIER — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# ============================================================

# === LIGHTFUNNEL ===
# Trouve-le dans : Lightfunnel → Settings → Integrations → Webhooks → Client Secret
LIGHTFUNNEL_CLIENT_SECRET=ton_client_secret_ici

# === WHATSAPP META CLOUD API ===
# Trouve-le dans : developers.facebook.com → Ton App → WhatsApp → Configuration
WA_PHONE_NUMBER_ID=123456789012345
WA_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WA_API_VERSION=v19.0

# === MARCHÉ CIBLE ===
# DZ = Algérie (Darija), FR = Français, ES = Espagnol, PT = Portugais
MARKET=DZ

# === SERVEUR ===
PORT=3000
NODE_ENV=production
